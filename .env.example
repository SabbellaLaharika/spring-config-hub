# The active Spring profile for the inventory-service (e.g., dev, prod)
SPRING_PROFILES_ACTIVE=dev

# Port mapping on the host to map inventory-service port (8081 for dev, 8082 for prod)
PORT_MAPPING=8081:8081

# The URI pointing to the Git-backed configuration repository inside the container mount path
SPRING_CLOUD_CONFIG_SERVER_GIT_URI=file:///etc/config-repo

# The URI pointing to the central configuration server used by microservice clients
SPRING_CLOUD_CONFIG_URI=http://config-server:8888
